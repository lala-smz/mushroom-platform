# ============================================
# 服务器配置
# ============================================
PORT=${{ PORT:-3303 }}
NODE_ENV=${{ NODE_ENV:-development }}
HOST=${{ HOST:-0.0.0.0 }}

# ============================================
# 数据库配置
# ============================================
DB_HOST=${{ MYSQLHOST:-localhost }}
DB_PORT=${{ MYSQLPORT:-3306 }}
DB_USER=${{ MYSQLUSER:-root }}
DB_PASSWORD=${{ MYSQLPASSWORD:-123456 }}
DB_NAME=${{ MYSQLDATABASE:-mushroom_db }}
DB_CHARSET=utf8mb4
DB_TIMEZONE=Asia/Shanghai

# ============================================
# Redis配置
# ============================================
REDIS_HOST=${{ REDISHOST:-localhost }}
REDIS_PORT=${{ REDISPORT:-6379 }}
REDIS_PASSWORD=${{ REDISPASSWORD:- }}
REDIS_DB=${{ REDISDB:-0 }}
REDIS_URL=${{ REDIS_URL:-redis://localhost:6379 }}
REDIS_TIMEOUT=5000

# ============================================
# JWT配置
# ============================================
JWT_SECRET=${{ JWT_SECRET:-mushroom_platform_jwt_secret_key_2024 }}
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# 文件上传配置
# ============================================
UPLOAD_PATH=${{ UPLOAD_PATH:-./uploads }}
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ============================================
# 安全配置
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5000
BOXES_RATE_LIMIT_MAX=10000

# ============================================
# CORS配置
# ============================================
CORS_ORIGIN=${{ CORS_ORIGIN:-http://localhost:5173,http://localhost:5174,http://localhost:3003 }}
FRONTEND_URL=${{ FRONTEND_URL:- }}
RAILWAY_EXTERNAL_URL=${{ RAILWAY_EXTERNAL_URL:- }}
RENDER_EXTERNAL_URL=${{ RENDER_EXTERNAL_URL:- }}

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=${{ LOG_LEVEL:-info }}
LOG_DIR=${{ LOG_DIR:-./logs }}

# ============================================
# Socket配置
# ============================================
SOCKET_PORT=${{ PORT:-3303 }}

# ============================================
# 缓存配置
# ============================================
CACHE_TTL=3600
CACHE_ENABLED=true

# ============================================
# 邮件配置（可选）
# ============================================
MAIL_HOST=${{ MAIL_HOST:-smtp.example.com }}
MAIL_PORT=${{ MAIL_PORT:-587 }}
MAIL_USER=${{ MAIL_USER:- }}
MAIL_PASS=${{ MAIL_PASS:- }}
MAIL_FROM=noreply@mushroom-platform.com